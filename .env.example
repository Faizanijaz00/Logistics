# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable the following APIs: Maps JavaScript API, Places API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# DVLA Vehicle Enquiry Service API Key (required for vehicle lookup)
# Register at: https://developer-portal.driver-vehicle-licensing.api.gov.uk
VITE_DVLA_API_KEY=your_dvla_api_key_here

# DVSA MOT History API Key (optional - for MOT expiry dates & history)
# Register at: https://documentation.history.mot.api.gov.uk
VITE_MOT_API_KEY=your_mot_api_key_here
