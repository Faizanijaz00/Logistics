{
  "expo": {
    "name": "Logistics",
    "slug": "logistics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "logistics",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.princypl.logistics",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.logistics.app",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Logistics to access your photos so you can attach fuel receipts, ticket notices, and issue photos.",
          "cameraPermission": "Allow Logistics to use the camera so you can photograph fuel receipts, ticket notices, and issues."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6a30b6f3-e333-4d61-a18e-a22312ab628b"
      }
    },
    "owner": "ivoines242",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6a30b6f3-e333-4d61-a18e-a22312ab628b"
    }
  }
}
