# Server Configuration
PORT=3001
NODE_ENV=production

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN_2=

# JWT Secret (MUST be changed in production - generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Traccar GPS Server
TRACCAR_URL=https://tracking.vigitech.uk
TRACCAR_USERNAME=your-traccar-username
TRACCAR_PASSWORD=your-traccar-password
TRACCAR_POLL_INTERVAL=30000

# DVLA Vehicle Enquiry Service API Key
DVLA_API_KEY=your_dvla_api_key_here

# DVSA MOT History API (OAuth2)
MOT_CLIENT_ID=your_mot_client_id
MOT_CLIENT_SECRET=your_mot_client_secret
MOT_TOKEN_URL=https://api.mot.gov.uk/oauth/token
MOT_SCOPE=mot-history
MOT_API_KEY=your_mot_api_key

# Supabase (optional - uses embedded keys if not set)
SUPABASE_URL=https://bwwfrdwpcxzlvprswzne.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
